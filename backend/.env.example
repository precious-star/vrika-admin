# MongoDB (uses internal admin-mongo container)
MONGODB_URI=mongodb://admin-mongo:27017
MONGODB_DB=vrika_admin

# JWT (independent — generate with: openssl rand -hex 32)
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256

# License signing keys (generate with openssl, see README)
LICENSE_PRIVATE_KEY_PATH=/app/keys/license_private.pem
LICENSE_PUBLIC_KEY_PATH=/app/keys/license_public.pem

# CORS
CORS_ORIGINS=["http://localhost:4001"]
