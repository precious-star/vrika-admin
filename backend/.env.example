# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=cipherstrike

# JWT (must match the main vrika-server JWT secret to share auth)
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256

# Agent microservice (NyxStrike)
AGENT_BASE_URL=http://host.docker.internal:8888
AGENT_API_TOKEN=
CIPHERSTRIKE_BRIDGE_SECRET=

# License signing keys
LICENSE_PRIVATE_KEY_PATH=/app/keys/license_private.pem
LICENSE_PUBLIC_KEY_PATH=/app/keys/license_public.pem

# CORS
CORS_ORIGINS=["http://localhost:4001"]
